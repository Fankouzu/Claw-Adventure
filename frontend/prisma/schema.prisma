generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Schema maps Django tables in world.agent_auth — source of truth for columns
// is Django migrations; keep Prisma in sync when models change.

model Agent {
  id               String    @id
  name             String    @unique
  description      String    @default("")
  apiKeyHash       String    @unique @map("api_key_hash")
  apiKeyPrefix     String    @map("api_key_prefix")
  claimToken       String    @unique @map("claim_token")
  claimStatus      String    @default("pending") @map("claim_status")
  claimExpiresAt   DateTime? @map("claim_expires_at")
  twitterHandle    String?   @map("twitter_handle")
  tweetUrl         String?   @map("tweet_url")
  createdAt        DateTime  @default(now()) @map("created_at")
  claimedAt        DateTime? @map("claimed_at")
  lastActiveAt     DateTime? @map("last_active_at")
  level            Int       @default(1)
  experience       Int       @default(0)
  evenniaAccountId Int?      @map("evennia_account_id")

  // Mirrored EvAdventure Character stats (written by Evennia typeclass hooks)
  inWorldCharacterKey  String    @default("") @map("in_world_character_key") @db.VarChar(255)
  inWorldHp            Int       @default(0) @map("in_world_hp")
  inWorldHpMax         Int       @default(0) @map("in_world_hp_max")
  inWorldLevel         Int       @default(1) @map("in_world_level")
  inWorldXp            Int       @default(0) @map("in_world_xp")
  inWorldXpPerLevel    Int       @default(1000) @map("in_world_xp_per_level")
  inWorldCoins         Int       @default(0) @map("in_world_coins")
  inWorldStrength      Int       @default(1) @map("in_world_strength")
  inWorldDexterity     Int       @default(1) @map("in_world_dexterity")
  inWorldConstitution  Int       @default(1) @map("in_world_constitution")
  inWorldIntelligence  Int       @default(1) @map("in_world_intelligence")
  inWorldWisdom        Int       @default(1) @map("in_world_wisdom")
  inWorldCharisma      Int       @default(1) @map("in_world_charisma")
  inWorldSyncedAt      DateTime? @map("in_world_synced_at")

  ownerEmail            UserEmail?
  codesUsed             InvitationCode[]         @relation("InvitationCodeUsedBy")
  fissionCodesCreated   InvitationCode[]         @relation("InvitationCodeCreatedBy")
  invitationsSent       InvitationRelationship[] @relation("InviterAgent")
  invitationReceived    InvitationRelationship?  @relation("InviteeAgent")
  emailTokens           EmailToken[]
  sessions              AgentSession[]
  userAchievements      UserAchievement[]
  explorationProgress   ExplorationProgress[]

  @@index([apiKeyPrefix])
  @@index([claimStatus])
  @@map("agent_auth_agents")
}

model InvitationCode {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  codeType    String    @default("admin") @map("code_type")
  isUsed      Boolean   @default(false) @map("is_used")
  usedById    String?   @map("used_by_id")
  usedBy      Agent?    @relation("InvitationCodeUsedBy", fields: [usedById], references: [id], onDelete: SetNull)
  createdById String?   @map("created_by_id")
  createdBy   Agent?    @relation("InvitationCodeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  generation  Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  usedAt      DateTime? @map("used_at")
  note        String    @default("")
  relationships InvitationRelationship[]

  @@index([isUsed])
  @@map("agent_auth_invitation_codes")
}

model InvitationRelationship {
  id        BigInt   @id @default(autoincrement())
  inviterId String?  @map("inviter_id")
  inviter   Agent?   @relation("InviterAgent", fields: [inviterId], references: [id], onDelete: SetNull)
  inviteeId String   @unique @map("invitee_id")
  invitee   Agent    @relation("InviteeAgent", fields: [inviteeId], references: [id], onDelete: Cascade)
  codeId    Int?     @map("code_id")
  code      InvitationCode? @relation(fields: [codeId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("agent_auth_invitation_relationships")
}

model UserEmail {
  id         String    @id
  email      String    @unique
  agentId    String    @unique @map("agent_id")
  agent      Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  isVerified Boolean   @default(false) @map("is_verified")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  @@index([email])
  @@map("agent_auth_user_emails")
}

model EmailToken {
  id        String   @id
  token     String   @unique
  email     String
  tokenType String   @map("token_type")
  isUsed    Boolean  @default(false) @map("is_used")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  agentId   String?  @map("agent_id")
  agent     Agent?   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([email])
  @@map("agent_auth_email_tokens")
}

model AgentSession {
  id             String    @id
  agentId        String    @map("agent_id")
  agent          Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  connectedAt    DateTime  @default(now()) @map("connected_at")
  disconnectedAt DateTime? @map("disconnected_at")
  ipAddress      String?   @map("ip_address")
  userAgent      String    @default("") @map("user_agent")

  @@index([agentId])
  @@map("agent_auth_sessions")
}

// world.achievements — read-only mirror of Django tables (see docs/ACHIEVEMENTS_DATABASE.md)

model Achievement {
  id          String   @id
  key         String   @unique
  name        String
  description String
  category    String
  points      Int      @default(10)
  isHidden    Boolean  @default(false) @map("is_hidden")
  icon        String   @default("")
  requirement Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  userUnlocks UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id
  agentId       String   @map("agent_id")
  achievementId String   @map("achievement_id")
  unlockedAt    DateTime @default(now()) @map("unlocked_at")

  agent       Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([agentId, achievementId])
  @@index([agentId])
  @@map("user_achievements")
}

model ExplorationProgress {
  id        String   @id
  agentId   String   @map("agent_id")
  roomKey   String   @map("room_key")
  roomName  String   @map("room_name")
  visitedAt DateTime @default(now()) @map("visited_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, roomKey])
  @@index([agentId])
  @@map("exploration_progress")
}
